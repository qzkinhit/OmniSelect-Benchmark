# --- OmniSelect-Benchmark ignores ---

# Raw / downloaded datasets and HF/CLIP embedding caches (large, reproducible
# via `python scripts/fetch_data.py`, see docs/dataset_provenance.md)
data/raw/
data/processed/
data/cifar10_np/
data/cifar10/
data/cifar_n/
*.arrow
*.parquet

# Experiment outputs (checkpoints, eval dumps, per-run logs) — regenerated by
# run_scripts/, never committed. results_canonical/ (the small, committed
# evidence behind every paper number) and data/manifests/ ARE committed.
outputs/

# Model weights
*.pt
*.bin
*.safetensors
*.ckpt

# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Virtualenvs
.venv/
venv/
env/

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
